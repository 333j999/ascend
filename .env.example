# ─── Supabase (required for auth + data) ─────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role — only needed for the cron endpoint to read auth.users.email.
# NEVER expose this client-side. Vercel marks env vars without NEXT_PUBLIC_
# as server-only automatically.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (required for daily email brief) ──────────
# Get a free key at https://resend.com
RESEND_API_KEY=
# Either "ASCEND <onboarding@resend.dev>" (uses Resend's shared sender, fine
# for testing) or "ASCEND <brief@yourdomain.com>" (after verifying your domain).
RESEND_FROM_EMAIL=

# ─── App URL (for links inside emails / OAuth) ────────
NEXT_PUBLIC_SITE_URL=https://your-vercel-url.vercel.app

# ─── Vercel Cron secret ───────────────────────────────
# Vercel sets this automatically for cron invocations. For local cron testing
# (`curl -H "Authorization: Bearer ..." http://localhost:3000/api/cron/...`)
# you can pick any random string.
CRON_SECRET=
